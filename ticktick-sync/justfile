image := "ghcr.io/diixtra/aios-ticktick-sync"
tag := "latest"

# Build the binary
build:
    go build -o bin/ticktick-sync ./cmd/

# Run all tests with race detection and coverage
test:
    go test ./... -v -race -cover

# Run linter
lint:
    golangci-lint run ./...

# Build Docker image
docker:
    docker build -t {{image}}:{{tag}} .

# Run tests then build
ci: test build
